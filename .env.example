# Database Configuration
DB_USERNAME=SK_USER
DB_PASSWORD=password123
DB_URL=jdbc:oracle:thin:@localhost:1521/FREEPDB1

# OAuth2 Kakao
KAKAO_CLIENT_ID=your_kakao_client_id
KAKAO_CLIENT_SECRET=your_kakao_client_secret
KAKAO_REDIRECT_URI=https://vceapp.com/login/oauth2/code/kakao

# OAuth2 Naver
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
NAVER_REDIRECT_URI=https://vceapp.com/login/oauth2/code/naver

# Security
JWT_SECRET=your_jwt_secret_key

# Deployment (vceapp.com)
FRONTEND_URL=https://vceapp.com
CORS_ALLOWED_ORIGINS=https://vceapp.com,https://www.vceapp.com
NEXT_PUBLIC_API_BASE_URL=https://api.vceapp.com
NEXT_PUBLIC_EXCHANGE_FRONTEND_URL=https://exchange.vceapp.com
NEXT_PUBLIC_BANK_FRONTEND_URL=https://bank.vceapp.com
NEXT_SERVER_ACTION_ALLOWED_ORIGINS=https://exchange.vceapp.com,https://bank.vceapp.com
SERVER_FORWARD_HEADERS_STRATEGY=framework

# Docker host binding/ports
APP_BIND_IP=0.0.0.0
HOST_BACKEND_PORT=18080
HOST_FRONTEND_PORT=15173
