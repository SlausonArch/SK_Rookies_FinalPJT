SPRING_DATASOURCE_URL=jdbc:oracle:thin:@//<RDS_ENDPOINT>:1521/<RDS_SERVICE_NAME>
SPRING_DATASOURCE_USERNAME=SK_USER
SPRING_DATASOURCE_PASSWORD=<RDS_PASSWORD>

# Default frontend for fallback redirect when frontend_url is not provided.
FRONTEND_URL=https://vceapp.com
CORS_ALLOWED_ORIGINS=https://vceapp.com,https://www.vceapp.com,https://bank.vceapp.com

JWT_SECRET=<JWT_SECRET>
KAKAO_CLIENT_ID=<KAKAO_CLIENT_ID>
KAKAO_CLIENT_SECRET=<KAKAO_CLIENT_SECRET>
NAVER_CLIENT_ID=<NAVER_CLIENT_ID>
NAVER_CLIENT_SECRET=<NAVER_CLIENT_SECRET>

# Use the backend public origin here.
KAKAO_REDIRECT_URI=https://<BACKEND_PUBLIC_URL>/login/oauth2/code/kakao
NAVER_REDIRECT_URI=https://<BACKEND_PUBLIC_URL>/login/oauth2/code/naver

SERVER_FORWARD_HEADERS_STRATEGY=framework
UPLOAD_DIR=/app/uploads
